{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "os:default",
    "sql:default",
    "sql:allow-execute",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "core:window:allow-start-dragging",
    "fs:default",
    "fs:allow-mkdir",
    "fs:allow-write-file",
    "fs:allow-remove",
    { "identifier": "fs:scope", "allow": ["$APPDATA/portraits/**"] },
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message"
  ]
}
